{
  "rootDirectory": "frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://campus-maintenance-api-nzjg.onrender.com/$1" },
    { "source": "/uploads/(.*)", "destination": "https://campus-maintenance-api-nzjg.onrender.com/uploads/$1" }
  ]
}
